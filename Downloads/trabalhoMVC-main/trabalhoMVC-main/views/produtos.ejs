<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
  <a href="/">Home</a>
  <a href="/sobre">Sobre</a>
  <a href="/contato">Contato</a>
  <a href="/produtos">Produtos</a>
</nav>

<div class="container">
  <h1>Produtos</h1>

  <a href="/produtos/novo"><button>Novo Produto</button></a>

  <ul>
    <% produtos.forEach(p => { %>
      <li>
        <strong><%= p.nome %></strong> - R$ <%= p.preco %>
        <div class="actions">
          <a href="/produtos/editar/<%= p.id %>">Editar</a>
          <a href="/produtos/deletar/<%= p.id %>">Excluir</a>
        </div>
      </li>
    <% }) %>
  </ul>
</div>

</body>
</html>