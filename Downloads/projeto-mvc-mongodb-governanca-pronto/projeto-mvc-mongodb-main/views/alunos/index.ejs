<%- include('../partials/header', { page: 'alunos' }) %>

<main>
  <section class="page-hero">
    <div class="page-tag">Gerenciamento</div>
    <h1 class="page-heading">Alunos</h1>
  </section>

  <section class="alunos-section">
    <div class="alunos-grid">

      <aside class="form-aside">
        <div class="form-card">
          <h3 class="form-card-title">Novo aluno</h3>
          <form action="/alunos" method="POST" class="aluno-form">
            <div class="field-group">
              <label class="field-label">Nome</label>
              <input class="field-input" type="text" name="nome" placeholder="Nome completo" required />
            </div>
            <div class="field-group">
              <label class="field-label">E-mail</label>
              <input class="field-input" type="email" name="email" placeholder="aluno@email.com" required />
            </div>
            <div class="field-group">
              <label class="field-label">Curso</label>
              <input class="field-input" type="text" name="curso" placeholder="Ex: Desenvolvimento Web" required />
            </div>
            <div class="field-group">
              <label class="field-label">Nota <span class="label-hint">0 – 10</span></label>
              <input class="field-input" type="number" name="nota" placeholder="8.5" min="0" max="10" step="0.1" required />
            </div>
            <button class="btn-primary full" type="submit">Cadastrar aluno</button>
          </form>
        </div>
      </aside>

      <div class="lista-col">
        <% if (erro) { %>
          <div class="alert alert-error"><%= erro %></div>
        <% } %>
        <% if (sucesso) { %>
          <div class="alert alert-ok">
            <% if (sucesso === 'cadastrado') { %>Aluno cadastrado com sucesso!<% } %>
            <% if (sucesso === 'atualizado') { %>Aluno atualizado com sucesso!<% } %>
            <% if (sucesso === 'removido')   { %>Aluno removido com sucesso!<% } %>
          </div>
        <% } %>

        <div class="lista-header">
          <h3 class="lista-titulo">Cadastrados <span class="count-badge"><%= alunos.length %></span></h3>
        </div>

        <% if (alunos.length === 0) { %>
          <div class="empty-box">
            <div class="empty-icon">○</div>
            <p>Nenhum aluno cadastrado ainda.</p>
            <span>Use o formulário ao lado para começar.</span>
          </div>
        <% } else { %>
          <div class="alunos-list">
            <% alunos.forEach(function(aluno) { %>
              <div class="aluno-row">
                <div class="aluno-left">
                  <div class="aluno-avatar"><%= aluno.nome.charAt(0).toUpperCase() %></div>
                  <div class="aluno-data">
                    <span class="aluno-nome"><%= aluno.nome %></span>
                    <span class="aluno-email"><%= aluno.email %></span>
                    <span class="aluno-curso"><%= aluno.curso %></span>
                  </div>
                </div>
                <div class="aluno-right">
                  <span class="nota-chip <%= aluno.nota >= 7 ? 'chip-green' : aluno.nota >= 5 ? 'chip-yellow' : 'chip-red' %>">
                    <%= aluno.nota.toFixed(1) %>
                  </span>
                  <div class="row-actions">
                    <a href="/alunos/<%= aluno._id %>/editar" class="btn-row-edit">Editar</a>
                    <button
                      class="btn-row-del"
                      onclick="openModal('<%= aluno._id %>', '<%= aluno.nome.replace(/'/g, `\\'`) %>')"
                      type="button">
                      Excluir
                    </button>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>
  </section>
</main>

<%- include('../partials/footer') %>
