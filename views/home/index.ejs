<%- include('../partials/header', { page: 'home' }) %>

<main>
  <section class="hero-section">
    <div class="hero-tag">Sistema MVC + MongoDB</div>
    <h1 class="hero-heading">
      Gestão de<br>
      <em>Alunos</em><br>
      Simplificada.
    </h1>
    <p class="hero-desc">Cadastre, edite e organize alunos com uma interface limpa e um back-end robusto.</p>
    <div class="hero-actions">
      <a href="/alunos" class="btn-primary">Gerenciar alunos →</a>
      <a href="/sobre"  class="btn-ghost">Saiba mais</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num">MVC</span><span class="stat-label">Arquitetura</span></div>
      <div class="stat-divider"></div>
      <div class="stat"><span class="stat-num">NoSQL</span><span class="stat-label">Banco de dados</span></div>
      <div class="stat-divider"></div>
      <div class="stat"><span class="stat-num">CRUD</span><span class="stat-label">Operações</span></div>
    </div>
  </section>

  <section class="cards-section">
    <div class="cards-grid">
      <div class="info-card">
        <div class="card-number">01</div>
        <h3>Cadastro rápido</h3>
        <p>Adicione alunos com nome, e-mail, curso e nota em segundos.</p>
      </div>
      <div class="info-card">
        <div class="card-number">02</div>
        <h3>Edição precisa</h3>
        <p>Atualize qualquer informação de um aluno de forma direta e segura.</p>
      </div>
      <div class="info-card accent-card">
        <div class="card-number">03</div>
        <h3>Persistência real</h3>
        <p>Todos os dados são salvos no MongoDB Atlas, sem perda entre sessões.</p>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
