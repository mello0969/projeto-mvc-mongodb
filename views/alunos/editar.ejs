<%- include('../partials/header', { page: 'alunos' }) %>

<main>
  <section class="page-hero">
    <div class="page-tag">Editando</div>
    <h1 class="page-heading">Editar aluno</h1>
  </section>

  <section class="edit-section">
    <div class="edit-wrap">
      <% if (erro) { %>
        <div class="alert alert-error"><%= erro %></div>
      <% } %>

      <div class="form-card">
        <form action="/alunos/<%= aluno._id %>/editar" method="POST" class="aluno-form">
          <div class="fields-row">
            <div class="field-group">
              <label class="field-label">Nome</label>
              <input class="field-input" type="text" name="nome" value="<%= aluno.nome %>" required />
            </div>
            <div class="field-group">
              <label class="field-label">E-mail</label>
              <input class="field-input" type="email" name="email" value="<%= aluno.email %>" required />
            </div>
          </div>
          <div class="fields-row">
            <div class="field-group">
              <label class="field-label">Curso</label>
              <input class="field-input" type="text" name="curso" value="<%= aluno.curso %>" required />
            </div>
            <div class="field-group">
              <label class="field-label">Nota</label>
              <input class="field-input" type="number" name="nota" value="<%= aluno.nota %>" min="0" max="10" step="0.1" required />
            </div>
          </div>
          <div class="edit-footer">
            <a href="/alunos" class="btn-ghost">← Cancelar</a>
            <button class="btn-primary" type="submit">Salvar alterações →</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
